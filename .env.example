# ============================================================================
# Self-Bot configuration — copy to .env and fill in.
# ============================================================================

# --- Management bot (Bot API) ----------------------------------------------
# Create a bot with @BotFather and paste the token here.
BOT_TOKEN=123456:ABC-DEF_your_bot_token

# --- Telegram MTProto application credentials -------------------------------
# Get these from https://my.telegram.org -> API development tools.
API_ID=1234567
API_HASH=0123456789abcdef0123456789abcdef

# --- Authorized users -------------------------------------------------------
# Comma-separated numeric Telegram user IDs allowed to control the bot
# (the only people the bot responds to). Get your ID from @userinfobot.
WHITELIST=111111111,222222222

# --- Webhook / deployment ---------------------------------------------------
# Leave PUBLIC_URL empty for LOCAL mode (long polling).
# On Railway set it to your public domain to enable webhook mode, e.g.
#   https://your-app.up.railway.app
PUBLIC_URL=
# Path the webhook is served on (default /tg/webhook).
WEBHOOK_PATH=/tg/webhook
# Optional shared secret validated on every webhook call (recommended).
WEBHOOK_SECRET=
# HTTP port. Railway injects PORT automatically; locally defaults to 8080.
PORT=8080

# --- Storage ----------------------------------------------------------------
# Path to the SQLite file. On Railway, point this at a mounted volume so the
# session survives restarts, e.g. /data/selfbot.sqlite
DB_PATH=data/selfbot.sqlite

# --- UI / behavior ----------------------------------------------------------
DEFAULT_LANG=fa
# Global minimum seconds between two profile pushes (anti-ban safety floor).
MIN_UPDATE_GAP_SEC=20
# Set to "debug" for verbose logs.
LOG_LEVEL=info

# --- Device fingerprint reported to Telegram (looks like a real client) -----
DEVICE_MODEL=Samsung Galaxy S23 Ultra
SYSTEM_VERSION=Android 14 (SDK 34)
APP_VERSION=Telegram Android 11.2.0
LANG_CODE=en
